{
  "name": "open-commander",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "npm run build && wrangler dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy:pages": "npm run build && npx wrangler pages deploy dist --project-name open-commander",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "exceljs": "4.4.0",
    "lucide-react": "1.8.0",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.33.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "typescript": "6.0.3",
    "vite": "8.0.9",
    "vitest": "4.1.5",
    "wrangler": "^4.84.1"
  }
}
